{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tool_call.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_name",
    "arguments"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "arguments": {
      "type": "object"
    }
  }
}
