{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "emotion_state.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "state_id",
    "user_id",
    "intensities",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "state_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "intensities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "happy",
        "sad",
        "angry",
        "fear",
        "disgust",
        "surprised",
        "neutral",
        "relaxed"
      ],
      "properties": {
        "happy": { "type": "number", "minimum": 0, "maximum": 10 },
        "sad": { "type": "number", "minimum": 0, "maximum": 10 },
        "angry": { "type": "number", "minimum": 0, "maximum": 10 },
        "fear": { "type": "number", "minimum": 0, "maximum": 10 },
        "disgust": { "type": "number", "minimum": 0, "maximum": 10 },
        "surprised": { "type": "number", "minimum": 0, "maximum": 10 },
        "neutral": { "type": "number", "minimum": 0, "maximum": 10 },
        "relaxed": { "type": "number", "minimum": 0, "maximum": 10 }
      }
    },
    "last_signal_source": {
      "type": "string"
    },
    "last_signal_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
