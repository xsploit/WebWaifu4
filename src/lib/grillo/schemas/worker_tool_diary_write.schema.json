{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "worker_tool_diary_write.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "personal_thought",
    "tags"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "interaction_summary": {
      "type": "string",
      "minLength": 1
    },
    "user_message": {
      "type": "string",
      "minLength": 1
    },
    "personal_thought": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "context_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "involved_users": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "emotions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "intensity"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "intensity": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          }
        }
      }
    },
    "beat_type": {
      "type": "string",
      "minLength": 1
    }
  }
}
