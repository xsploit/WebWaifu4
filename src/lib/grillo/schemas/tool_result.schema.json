{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tool_result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool_name",
    "ok",
    "result"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "tool_name": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "result": {
      "type": "object"
    },
    "error": {
      "type": "string"
    }
  }
}
