{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "envelope.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_type",
    "schema_version",
    "trace_id",
    "turn_id",
    "user_id",
    "channel_id",
    "created_at",
    "payload"
  ],
  "properties": {
    "message_type": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "string",
      "minLength": 1
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "channel_id": {
      "type": "string",
      "minLength": 1
    },
    "interface_path": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "idempotency_key": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    }
  }
}
