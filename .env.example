# YourWifey Local environment.
# Copy to .env.local for local development.

# Browser app defaults.
VITE_AI_PROXY_ENABLED=true
# Leave blank to use same-origin /api proxy in Vite/serve-dist.
# Set only if you intentionally want direct browser -> backend requests.
VITE_AI_PROXY_URL=
VITE_DIRECT_TWITCH_CHAT=true
VITE_STREAM_BOT_WS_ENABLED=false
VITE_TWITCH_CHANNEL=

# Local backend.
BOT_PORT=8787
OVERLAY_PORT=5173
TWITCH_MOCK=true

# Optional server-side fallback provider keys.
# The preferred path is Settings -> Account -> Browser Provider Keys.
# Set BYOK_SERVER_PROVIDER_PROXY_ENABLED=true only if you want this local backend
# to use these ENV keys when the browser vault has no key.
BYOK_SERVER_PROVIDER_PROXY_ENABLED=false
OPENAI_API_KEY=
OPENROUTER_API_KEY=
FISH_AUDIO_API_KEY=
INWORLD_API_KEY=
TAVILY_API_KEY=

# Optional Twitch stream transcription/vision helpers.
# Requires ffmpeg plus yt-dlp or streamlink installed on PATH.
TWITCH_STREAM_CAPTURE_TOOL=yt-dlp
TWITCH_STREAM_AUDIO_SAMPLE_SECONDS=20

# Optional signed websocket overlay mode for non-localhost access.
OVERLAY_SIGNING_SECRET=
