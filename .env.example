# YourWifey BYOK local/Vercel environment.
# Copy to .env.local for local work or map these names in Vercel project settings.

# Browser-visible Supabase config. These are safe public values from Supabase.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Legacy alias still supported:
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase config for /api/byok/* routes.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-server-only-supabase-secret-key
# Legacy aliases still supported:
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SUPABASE_JWT_SECRET=your-server-only-jwt-secret
SUPABASE_STORAGE_BUCKET=yourwifey-assets

# Server-only overlay token signing. If omitted, the API falls back to other
# server-only Supabase secrets, but a dedicated value is preferred.
OVERLAY_SIGNING_SECRET=your-server-only-overlay-signing-secret

# Optional AI/TTS proxy defaults for local/VPS mode.
AI_PROVIDER=openai-responses-ws
OPENAI_MODEL=gpt-5.4-nano
OPENAI_WS_URL=wss://api.openai.com/v1/responses
TTS_PROVIDER=piper
TWITCH_MOCK=true
BOT_PORT=8787

# Provider API keys are BYOK browser-local for v1. Do not add VITE_ provider
# secret variables unless you are intentionally exposing them to the browser.
