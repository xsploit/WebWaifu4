{
  "name": "yourwifey-local",
  "version": "1.0.0",
  "description": "Standalone Twitch-first web waifu stream overlay.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n overlay,ai -c cyan,magenta \"cross-env VITE_DIRECT_TWITCH_CHAT=true VITE_STREAM_BOT_WS_ENABLED=false VITE_AI_PROXY_ENABLED=true vite --host 0.0.0.0\" \"cross-env TWITCH_MOCK=true npm run dev:ai\"",
    "dev:overlay": "cross-env VITE_DIRECT_TWITCH_CHAT=true VITE_STREAM_BOT_WS_ENABLED=false vite --host 0.0.0.0",
    "dev:ai": "tsx server/src/index.ts",
    "_build": "tsc && vite build",
    "build": "npm run _build && npm run build:bot",
    "build:bot": "tsc -p tsconfig.server.json",
    "dev:bot": "cross-env TWITCH_MOCK=true npm run dev:ai",
    "dev:bot:irc": "cross-env TWITCH_MOCK=false npm run dev:ai",
    "preview": "vite preview",
    "start:bot": "cross-env TWITCH_MOCK=true node server/dist/index.js",
    "start:bot:irc": "cross-env TWITCH_MOCK=false node server/dist/index.js",
    "start:stream": "concurrently -k -n overlay,ai -c cyan,magenta \"npm run preview -- --host 0.0.0.0\" \"npm run start:bot\"",
    "sync:silly-tavern": "node scripts/sync-silly-tavern.mjs",
    "test": "vitest",
    "deploy": "npm run build",
    "format": "prettier \"{src,public}/**/*.{ts,tsx,js,jsx,json,css,html}\" --write",
    "format:check": "prettier \"{src,public}/**/*.{ts,tsx,js,jsx,json,css,html}\" --check"
  },
  "keywords": [
    "react",
    "vite",
    "typescript",
    "three.js",
    "react-three-fiber",
    "Twitch"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/three": "~0.170.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@inworld/tts": "^1.1.1",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "@pixiv/three-vrm": "^3.5.1",
    "@pixiv/three-vrm-animation": "^3.5.1",
    "@react-three/drei": "^9.121.0",
    "@react-three/fiber": "^8.17.0",
    "dotenv": "^17.4.2",
    "fish-audio": "^0.1.0",
    "ioredis": "^5.10.1",
    "onnxruntime-web": "^1.18.0",
    "phonemizer": "^1.2.1",
    "pomljs": "file:vendor/pomljs-0.0.9.tgz",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "~0.170.0",
    "wlipsync": "^1.3.0",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  }
}
